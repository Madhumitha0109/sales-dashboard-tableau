      <column caption='seafood_data_with_kpis_seafood_data_with_kpis.csv' datatype='table' name='[__tableau_internal_object_id__].[seafood_data_with_kpis_seafood_data_with_kpis.csv_2E9EDAF23BB340C38CD178E3DA5950C2]' role='measure' type='quantitative' />
      <column-instance column='[Calculation_0884041996980227]' derivation='None' name='[none:Calculation_0884041996980227:nk]' pivot='key' type='nominal' />
      <column-instance column='[Inventory]' derivation='Sum' name='[sum:Inventory:qk]' pivot='key' type='quantitative' />
