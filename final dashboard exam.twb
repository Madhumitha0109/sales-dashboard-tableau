      <aliases enabled='yes' />
      <column caption='Avg Units per Order' datatype='real' name='[Average order size]' role='measure' type='quantitative' />
      <column caption='Order Date (Parsed)' datatype='date' hidden='true' name='[Calculation_0884041989173248]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(DATEPARSE(&quot;dd-MM-yyyy&quot;, STR([Order Date])))' />
      </column>
      <column caption='Order Date (Clean)' datatype='date' hidden='true' name='[Calculation_0884041990049793]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='MAKEDATE(&#13;&#10;    INT(SPLIT(STR([Order Date]), &quot;-&quot;, 1)),&#13;&#10;    INT(SPLIT(STR([Order Date]), &quot;-&quot;, 2)),&#13;&#10;    INT(SPLIT(STR([Order Date]), &quot;-&quot;, 3))&#13;&#10;)' />
      </column>
      <column caption='Profit Margin %' datatype='real' default-format='p0.00%' name='[Calculation_0884041993650178]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Profit margin] / 100' />
      </column>
      <column caption='Profit Quality' datatype='string' name='[Calculation_0884041996980227]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0884041993650178] &lt; 0 THEN &quot;Loss-Making&quot;&#13;&#10;ELSEIF [Calculation_0884041993650178] &lt; 0.10 THEN &quot;Low Margin&quot;&#13;&#10;ELSE &quot;Healthy&quot;&#13;&#10;END' />
      </column>
      <column caption='Revenue per Kg' datatype='real' name='[Calculation_0884041997803524]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue]) / SUM([Weight])' />
      </column>
      <column caption='Inventory Risk Status' datatype='string' name='[Calculation_0884041998020613]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Inventory turnover] &lt; 2 THEN &quot;Overstock Risk&quot;&#13;&#10;ELSEIF [Inventory turnover] &gt; 8 THEN &quot;Stockout Risk&quot;&#13;&#10;ELSE &quot;Balanced&quot;&#13;&#10;END' />
      </column>
      <column caption='Weighted Profit Margin' datatype='real' default-format='p0.00%' name='[Calculation_0884041998483462]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Revenue])' />
      </column>
      <column caption='Revenue per Order Unit' datatype='real' name='[Calculation_0884041998860295]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue]) / SUM([Average order size])' />
      </column>
      <column caption='Unit Cost Pressure' datatype='real' name='[Calculation_0884041999138824]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Cost per unit] + [Item Processing cost]' />
      </column>
      <column caption='Action Required?' datatype='string' name='[Calculation_0884041999319049]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0884041996980227] = &quot;Loss-Making&quot;&#13;&#10;OR [Calculation_0884041998020613] &lt;&gt; &quot;Balanced&quot;&#13;&#10;THEN &quot;Yes&quot;&#13;&#10;ELSE &quot;No&quot;&#13;&#10;END' />
      </column>
      <column caption='Action Required %' datatype='real' default-format='p0.00%' name='[Calculation_0884042010079242]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [Calculation_0884041999319049] = &quot;Yes&quot; THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([Order ID])' />
      </column>
      <column caption='Revenue (Jitter)' datatype='real' name='[Calculation_0884042022981643]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue]) &#13;&#10;+ &#13;&#10;(RANDOM() - 0.5) * 200000' />
      </column>
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column datatype='integer' name='[Inventory]' role='measure' type='quantitative' />
      <column datatype='integer' name='[Order ID]' role='dimension' type='ordinal' />
      <column datatype='string' name='[Product]' role='dimension' type='nominal' />
      <column datatype='real' hidden='true' name='[Profit margin]' role='measure' type='quantitative' />
      <column datatype='integer' default-format='c&quot;₹ &quot;#,##0,,.0M;&quot;₹ &quot;-#,##0,,.0M' name='[Profit]' role='measure' type='quantitative' />
      <column datatype='integer' default-format='n#,##0,,.0M;-#,##0,,.0M' name='[Revenue]' role='measure' type='quantitative' />
      <column datatype='string' name='[Shipping Company]' role='dimension' type='nominal' />
      <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
      <column datatype='integer' hidden='true' name='[Year]' role='dimension' type='quantitative' />
